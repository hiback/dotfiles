#!/usr/bin/env bash
set -euo pipefail

PORT=4096
LOG="${TMPDIR:-/tmp}/opencode-server.$(date +%Y%m%d-%H%M%S).log"

opencode serve --hostname 0.0.0.0 --port "$PORT" >"$LOG" 2>&1 &
SERVER_PID=$!

cleanup() {
  kill "$SERVER_PID" 2>/dev/null || true
  wait "$SERVER_PID" 2>/dev/null || true
}
trap cleanup EXIT

opencode attach "http://127.0.0.1:$PORT"
