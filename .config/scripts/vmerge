#!/bin/bash

# =========================================================
# 脚本名称: vmerge
# 功能: 使用 mkvmerge 智能无损合并视频
# 优势: 自动检测兼容性，拒绝生成结构损坏的文件
# =========================================================

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

die() {
  echo -e "${RED}$1${NC}"
  read -p "按Enter键退出"
  exit 1
}

# 0. 脚本开始
echo -e "----------------------------------------"

# 1. 检查依赖
if ! command -v mkvmerge &>/dev/null; then
  die "错误: 未找到 mkvmerge。请安装 MKVToolNix (例如: sudo apt install mkvtoolnix)。"
fi

# 2. 检查参数数量
if [ "$#" -lt 2 ]; then
  die "用法: $(basename "$0") <视频1> <视频2> [视频3...]"
fi

input_files=("$@")

# 3. 验证所有输入文件是否存在
for file in "${input_files[@]}"; do
  if [ ! -f "$file" ]; then
    die "错误: 文件 '$file' 不存在。"
  fi
done

# 4. 生成输出文件名 (基于第一个文件)
first_file="${input_files[0]}"
filename=$(basename -- "$first_file")
filename_no_ext="${filename%.*}"

# 去除常见的 cd1, CD1 尾缀，保持文件名整洁
filename_no_ext=$(echo "$filename_no_ext" | sed -E 's/-[cC][dD][1-9]$//')

# 基础输出名
output_base="${filename_no_ext}-merged"
output_extension="mkv"
output_file="${output_base}.${output_extension}"

# 自动处理文件名冲突 (如果存在则 file-merged-1.mkv, -2.mkv ...)
counter=1
while [ -f "$output_file" ]; do
  output_file="${output_base}-${counter}.${output_extension}"
  ((counter++))
done

# 5. 构建 mkvmerge 命令参数
# mkvmerge 的逻辑是: -o 输出 input1 + input2 + input3
# 注意: 第一个文件前不需要加 +，后续文件前必须加 + 以表示“追加”而不是“并列轨道”

merge_args=("-o" "$output_file")
is_first=true

echo -e "${GREEN}准备合并 ${#input_files[@]} 个文件...${NC}"
echo "输出目标: $output_file"

for file in "${input_files[@]}"; do
  if [ "$is_first" = true ]; then
    # 第一个文件直接添加
    merge_args+=("$file")
    is_first=false
  else
    # 后续文件前加 + 号 (作为独立的参数传递)
    merge_args+=("+" "$file")
  fi
done

# 6. 执行合并
echo -e "${CYAN}正在调用 mkvmerge 执行合并...${NC}"

# 执行命令并捕获退出代码
# "$@" 方式可以完美处理文件名中的空格
mkvmerge "${merge_args[@]}"
exit_code=$?

# 7. 结果判断
if [ $exit_code -eq 0 ]; then
  echo -e "${GREEN}✅ 合并成功！${NC}"
  echo "文件已保存为: $output_file"
elif [ $exit_code -eq 1 ]; then
  echo -e "${YELLOW}⚠️ 合并完成，但存在警告 (代码 1)。${NC}"
  echo "文件可能可以播放，但请务必检查是否存在音画同步问题。"
  echo "文件已保存为: $output_file"
  read -p "按Enter键结束"
else
  # 退出代码 2 通常表示错误且未生成文件
  echo -e "${RED}❌ 合并失败 (代码 $exit_code)。${NC}"
  echo "原因可能是：分辨率/编码不匹配、文件损坏或缺少必要的编解码信息。"
  echo "mkvmerge 拒绝合并不兼容的文件以防止产生无法播放的垃圾文件。"
  die "请检查上方具体的错误日志。"
fi
