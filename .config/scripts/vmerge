#!/bin/bash

# =========================================================
# 脚本名称: vmerge
# 功能: mkvmerge 合并 + 智能参数解析 + 严格检查
# =========================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

die() {
  echo -e "\n${RED}$1${NC}"
  [ -z "$2" ] && read -p "按Enter键退出"
  exit 1
}

check_dep() {
  if ! command -v "$1" &>/dev/null; then
    die "错误: 未找到命令 '$1'。请先安装它。"
  fi
}

# 0. Start
echo "----------------------------------------"

# 1. 检查依赖
check_dep mkvmerge
check_dep ffprobe

if [ "$#" -lt 2 ]; then
  die "用法: $(basename "$0") <视频1> <视频2> [视频3...]"
fi

input_files=("$@")
first_file="${input_files[0]}"

# --- 定义智能获取参数函数 ---
analyze_video() {
  local file="$1"
  local prefix="$2" # 变量前缀，如 ref_ 或 cur_

  # 初始化变量
  eval "${prefix}w=''"
  eval "${prefix}h=''"
  eval "${prefix}pix=''"
  eval "${prefix}prof=''"
  eval "${prefix}lvl=''"
  local c_space="" c_prim="" c_trans=""

  # 获取元数据，输出格式为: width=1920 \n height=1080 ...
  local raw_data
  raw_data=$(ffprobe -v error -select_streams v:0 \
    -show_entries stream=width,height,pix_fmt,profile,level,color_space,color_primaries,color_transfer \
    -of default=noprint_wrappers=1:nokey=0 "$file")

  if [ -z "$raw_data" ]; then return 1; fi

  # 逐行解析
  while IFS='=' read -r key value; do
    # 去除可能存在的行尾回车符 (兼容性处理)
    value=$(echo "$value" | tr -d '\r')

    case "$key" in
    width) eval "${prefix}w='$value'" ;;
    height) eval "${prefix}h='$value'" ;;
    pix_fmt) eval "${prefix}pix='$value'" ;;
    profile) eval "${prefix}prof='$value'" ;;
    level) eval "${prefix}lvl='$value'" ;;
    color_space) c_space="$value" ;;
    color_primaries) c_prim="$value" ;;
    color_transfer) c_trans="$value" ;;
    esac
  done <<<"$raw_data"

  # 组合色彩信息 (处理 unknown 的情况)
  local full_color="${c_space}:${c_prim}:${c_trans}"
  # 如果全是 unknown 或空，设为统一标识以便比较
  if [[ "$full_color" == "unknown:unknown:unknown" ]]; then full_color="default"; fi
  eval "${prefix}color='$full_color'"

  return 0
}

# 3. 获取基准参数
echo -e "${GREEN}正在执行深度兼容性检查...${NC}"

# 调用函数，前缀使用 ref_
if ! analyze_video "$first_file" "ref_"; then
  die "错误: '$first_file' 不是有效的视频。"
fi

echo -e "${CYAN}基准文件: $(basename "$first_file")${NC}"
echo "  分辨率: ${ref_w}x${ref_h}"
echo "  格式: $ref_pix | $ref_prof @ $ref_lvl"
echo "  色彩: $ref_color"

# 4. 循环严格检查
for file in "${input_files[@]}"; do
  [ "$file" == "$first_file" ] && continue
  if [ ! -f "$file" ]; then die "文件 '$file' 不存在"; fi

  # 调用函数，前缀使用 cur_
  if ! analyze_video "$file" "cur_"; then
    die "无法解析文件: $file"
  fi

  fname=$(basename "$file")
  error_msg=""

  # --- 比较逻辑 ---

  # 1. 分辨率 (严格)
  if [ "$cur_w" != "$ref_w" ] || [ "$cur_h" != "$ref_h" ]; then
    error_msg="分辨率不一致 ($cur_w x $cur_h)"
  fi

  # 2. 像素格式 (严格)
  if [ "$cur_pix" != "$ref_pix" ]; then
    error_msg="像素格式不一致 ($cur_pix vs $ref_pix)"
  fi

  # 3. Profile (严格)
  if [ "$cur_prof" != "$ref_prof" ]; then
    error_msg="编码Profile不一致 ($cur_prof vs $ref_prof)"
  fi

  # 4. Level (警告)
  if [ "$cur_lvl" != "$ref_lvl" ]; then
    echo -e "${YELLOW}⚠️ 警告: '$fname' Level 不一致 ($cur_lvl vs $ref_lvl)。${NC}"
  fi

  # 5. 色彩空间 (严格，因为这会影响 Infuse/Jellyfin 显色)
  # 只有当两者都不是 default 时才比较
  if [ "$cur_color" != "default" ] && [ "$ref_color" != "default" ]; then
    if [ "$cur_color" != "$ref_color" ]; then
      # 这是一个潜在的高风险点，Infuse 可能会颜色显示错误
      echo -e "${YELLOW}⚠️ 警告: '$fname' 色彩元数据不一致 ($cur_color vs $ref_color)。${NC}"
    fi
  fi

  if [ -n "$error_msg" ]; then
    echo -e "${RED}❌ 检查失败: $fname${NC}"
    die "原因: $error_msg\n这会导致 Jellyfin/Infuse 播放崩溃。"
  fi
done

echo -e "${GREEN}检查通过！开始合并...${NC}"

# 5. 生成文件名
filename=$(basename -- "$first_file")
filename_no_ext="${filename%.*}"
# 去除 part1, cd1 等尾缀
filename_no_ext=$(echo "$filename_no_ext" | sed -E 's/[-_. ]*([cC][dD]|[pP][aA][rR][tT])[0-9]+$//')

output_file="${filename_no_ext}-merged.mkv"
counter=1
while [ -f "$output_file" ]; do
  output_file="${filename_no_ext}-merged-${counter}.mkv"
  ((counter++))
done

# 6. 构建 mkvmerge 命令
merge_args=("--gui-mode" "-o" "$output_file")
is_first=true
for file in "${input_files[@]}"; do
  if [ "$is_first" = true ]; then
    merge_args+=("$file")
    is_first=false
  else
    merge_args+=("+" "$file")
  fi
done

# 7. 执行合并
EXIT_CODE_FILE=$(mktemp)
trap 'rm -f "$EXIT_CODE_FILE"' EXIT

echo -e "${CYAN}正在调用 mkvmerge...${NC}"

(
  mkvmerge "${merge_args[@]}"
  echo $? >"$EXIT_CODE_FILE"
) | while IFS= read -r line; do
  case "$line" in
  "#GUI#progress"*)
    percent="${line#* }"
    printf "\r[进度]: %s    " "$percent"
    ;;
  "#GUI#warning"*)
    msg="${line#*warning: }"
    printf "\n${YELLOW}⚠️ 警告: %s${NC}\n" "$msg"
    ;;
  "#GUI#error"*)
    msg="${line#*error: }"
    printf "\n${RED}❌ 错误: %s${NC}\n" "$msg"
    ;;
  esac
done

echo ""
exit_code=$(cat "$EXIT_CODE_FILE")

if [ "$exit_code" -eq 0 ]; then
  echo -e "${GREEN}✅ 合并成功！文件: $output_file${NC}"
elif [ "$exit_code" -eq 1 ]; then
  echo -e "${YELLOW}⚠️ 合并完成但有警告。${NC}"
  read -p "按Enter键退出"
else
  die "❌ 合并失败。"
fi
